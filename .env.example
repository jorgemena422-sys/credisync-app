PORT=3001
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
JWT_SECRET=replace-with-very-long-random-secret-32-plus-chars
CORS_ORIGIN=http://localhost:5173
APP_PUBLIC_URL=http://localhost:3001
PUSH_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
PUSH_VAPID_PRIVATE_KEY=replace-with-vapid-private-key
PUSH_VAPID_SUBJECT=mailto:soporte@your-domain.com
PUSH_DAILY_SUMMARY_JOB_TOKEN=replace-with-long-internal-job-token
ENABLE_SUPERADMIN_BOOTSTRAP=false
SUPERADMIN_EMAIL=superadmin@your-domain.com
SUPERADMIN_PASSWORD=replace-with-temporary-bootstrap-password
SUPERADMIN_NAME=Super Administrador

# Optional smoke test variables
SMOKE_API_BASE=http://localhost:3001
SMOKE_ADMIN_EMAIL=admin@your-domain.com
SMOKE_ADMIN_PASSWORD=replace-with-admin-password
SMOKE_SUPERADMIN_EMAIL=superadmin@your-domain.com
