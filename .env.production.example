PORT=3001
NODE_ENV=production

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-rotated-service-role-key
SUPABASE_ANON_KEY=replace-with-rotated-anon-key

JWT_SECRET=replace-with-very-long-random-secret-32-plus-chars

# Same-domain recommendation for Firebase setup
APP_PUBLIC_URL=https://your-final-domain.com
CORS_ORIGIN=https://your-final-domain.com
SUPABASE_PROJECT_REF=your-project-ref
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=replace-with-verified-sender@your-domain.com
SENDGRID_FROM_NAME=CrediSync
SENDGRID_REPLY_TO_EMAIL=soporte@your-domain.com
PUSH_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
PUSH_VAPID_PRIVATE_KEY=replace-with-vapid-private-key
PUSH_VAPID_SUBJECT=mailto:soporte@your-domain.com
PUSH_DAILY_SUMMARY_JOB_TOKEN=replace-with-long-internal-job-token
ENABLE_LOCAL_PUSH_SCHEDULER=false

# Optional helpers for Cloud Scheduler -> Cloud Run direct deployment
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
CLOUD_RUN_SERVICE=credisync-api
CLOUD_RUN_REGION=us-central1
PUSH_DAILY_SUMMARY_SCHEDULER_JOB_NAME=credisync-push-daily-summary
PUSH_DAILY_SUMMARY_SCHEDULER_CRON=*/15 * * * *
PUSH_DAILY_SUMMARY_SCHEDULER_TIMEZONE=Etc/UTC

ENABLE_SUPERADMIN_BOOTSTRAP=false
SUPERADMIN_EMAIL=superadmin@your-domain.com
SUPERADMIN_PASSWORD=replace-with-temporary-bootstrap-password
SUPERADMIN_NAME=Super Administrador
